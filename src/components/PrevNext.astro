---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entries: CollectionEntry<'course'>[];
  current: CollectionEntry<'course'>;
}

const { entries, current } = Astro.props;
const idx = entries.findIndex(e => e.slug === current.slug);
const prev = idx > 0 ? entries[idx - 1] : null;
const next = idx < entries.length - 1 ? entries[idx + 1] : null;
---
<nav class="mt-12 pt-6 border-t border-gray-200 dark:border-gray-700 flex justify-between gap-4">
  {prev ? (
    <a href={`/course/${prev.slug}`} class="flex items-center gap-2 text-sm text-indigo-600 dark:text-indigo-400 hover:underline">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      {prev.data.title}
    </a>
  ) : <span />}
  {next ? (
    <a href={`/course/${next.slug}`} class="flex items-center gap-2 text-sm text-indigo-600 dark:text-indigo-400 hover:underline ml-auto">
      {next.data.title}
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    </a>
  ) : null}
</nav>
