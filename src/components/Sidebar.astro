---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entries: CollectionEntry<'course'>[];
  current?: string;
}

const { entries, current } = Astro.props;

const sections: Record<string, CollectionEntry<'course'>[]> = {};
for (const entry of entries) {
  if (!sections[entry.data.section]) sections[entry.data.section] = [];
  sections[entry.data.section].push(entry);
}
---
<aside id="sidebar" class="hidden md:block w-64 shrink-0 border-r border-gray-200 dark:border-gray-700 min-h-[calc(100vh-57px)] px-4 py-6 sticky top-14 overflow-y-auto max-h-[calc(100vh-57px)]">
  <nav>
    <a href="/course" class="block mb-4 text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider hover:text-indigo-600">
      Índice del Curso
    </a>
    {Object.entries(sections).map(([section, items]) => (
      <div class="mb-6">
        <h3 class="text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-2">{section}</h3>
        <ul class="space-y-1">
          {items.map(item => (
            <li>
              <a
                href={`/course/${item.slug}`}
                class={`block px-2 py-1 rounded text-sm transition-colors ${
                  current === item.slug
                    ? 'bg-indigo-50 dark:bg-indigo-900/30 text-indigo-600 dark:text-indigo-400 font-medium'
                    : 'text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800'
                }`}
              >
                {item.data.title}
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </nav>
</aside>
